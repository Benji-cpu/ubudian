# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example

# worktrees
.worktrees/

# claude code settings (contains secrets + machine-specific paths)
.claude/*
# but DO track committed agent prompts — these are versioned alongside the code
!.claude/agents/

# screenshots & test artifacts
*.png
*.jpeg
reparse-check.md
e2e/test-results/

# but DO track brand assets and Next.js metadata route images
!public/brand/*.png
!src/app/icon.png
!src/app/apple-icon.png
!src/app/opengraph-image.png

# tool directories
.playwright-mcp/
.agents/
.superpowers/
skills-lock.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
