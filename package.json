{
  "name": "ubudian-v1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :4000 | xargs kill 2>/dev/null; concurrently -n next,telegram -c cyan,magenta --success first \"next dev --port 4000\" \"tsx scripts/telegram-poll.ts\"",
    "dev:next": "lsof -ti :4000 | xargs kill 2>/dev/null; next dev --port 4000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:audit": "playwright test e2e/audit/ --reporter=html",
    "telegram:setup": "tsx scripts/telegram-setup.ts",
    "telegram:poll": "tsx scripts/telegram-poll.ts",
    "telegram:webhook": "tsx scripts/telegram-webhook.ts",
    "telegram:webhook:set": "tsx scripts/telegram-webhook.ts set",
    "telegram:webhook:delete": "tsx scripts/telegram-webhook.ts delete"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "^1.0.7",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@uiw/react-md-editor": "^4.0.11",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
